# === Required ===
# OpenAI API key for Whisper transcription and AI agents
# (required only if using whisper for transcription)
OPENAI_API_KEY=sk-your-openai-api-key-here

# === Optional: LLM Providers ===
# Default: gemini (falls back to openrouter, then copilot)

# Gemini (recommended - default)
GEMINI_API_KEY=your-gemini-api-key
# Additional fallback keys (comma-separated)
GEMINI_API_KEYS=key1,key2
# Model override (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (fallback)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_API_KEYS=key1,key2
# Model override (default: nvidia/nemotron-3-super-120b-a12b:free)
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Copilot (uses GitHub auth - no key needed)
# LLM_PROVIDER=copilot

# OpenAI (direct API)
# LLM_PROVIDER=openai
# OPENAI_API_KEY already set above

# Claude (direct Anthropic API)
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...

# === Optional: Transcription ===
# Options: whisper (default), assemblyai
TRANSCRIPTION_PROVIDER=whisper
# If using AssemblyAI:
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
ASSEMBLYAI_API_KEYS=key1,key2

# === Folder Configuration ===
# Folder to watch for new video recordings (default: ./watch)
WATCH_FOLDER=./watch
# Output directory for processed recordings (default: ./recordings)
OUTPUT_DIR=./recordings

# === Media Processing ===
# FFmpeg/FFprobe paths (default: auto-detected via ffmpeg-static)
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFPROBE_PATH=/usr/local/bin/ffprobe

# === Optional: Web Search ===
# Exa AI API key for enriching social posts with web links
EXA_API_KEY=your-exa-api-key

# === Optional: Social Publishing ===
# Sign up at https://getlate.dev
# LATE_API_KEY=sk_your_key_here
# LATE_PROFILE_ID=your_profile_id_here

# === Optional: GitHub Integration ===
# GitHub Personal Access Token for content ideation
# GITHUB_TOKEN=ghp_...
# GitHub repo for storing ideas as Issues (format: owner/repo)
IDEAS_REPO=owner/repo